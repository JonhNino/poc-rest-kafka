        { "expr": "rate(kafka_events_failed_total[1m])", "legendFormat": "fallidos/s", "refId": "B" }
      ]
    },
    {
      "title": "Latencia procesamiento ordenes (p50, p95, p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(orders_processing_duration_seconds_bucket[1m]))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(orders_processing_duration_seconds_bucket[1m]))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(orders_processing_duration_seconds_bucket[1m]))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "title": "Latencia publicacion Kafka (p50, p95, p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(kafka_events_publish_duration_seconds_bucket[1m]))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(kafka_events_publish_duration_seconds_bucket[1m]))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(kafka_events_publish_duration_seconds_bucket[1m]))", "legendFormat": "p99", "refId": "C" }
