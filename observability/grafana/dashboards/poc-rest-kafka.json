    {
      "title": "HTTP Server Requests (rate 1m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        { "expr": "rate(http_server_requests_seconds_count{uri=\"/orders\"}[1m])", "legendFormat": "{{method}} {{status}}", "refId": "A" }
      ]
    },
    {
      "title": "JVM Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
