      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "rate(orders_processed_total[1m])", "legendFormat": "procesadas/s", "refId": "A" },
        { "expr": "rate(orders_failed_total[1m])", "legendFormat": "fallidas/s", "refId": "B" }
      ]
    },
    {
      "title": "Kafka publish rate (1m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
