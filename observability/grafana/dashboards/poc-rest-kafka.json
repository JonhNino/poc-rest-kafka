    },
    {
      "title": "Ordenes Fallidas (total)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "orders_failed_total", "legendFormat": "fallidas", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }] } } }
    },
    {
      "title": "Eventos Kafka Publicados (total)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "kafka_events_published_total", "legendFormat": "publicados", "refId": "A" }
